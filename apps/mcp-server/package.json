{
  "name": "@coodra/contextos-mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "ContextOS MCP server — stdio transport (S5 walking skeleton), tool-registration framework with enforced invariants, typed env config, Clerk + solo-bypass auth chain (wired in later slices).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "contextos-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome check .",
    "dev": "CONTEXTOS_LOG_DESTINATION=stderr tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@coodra/contextos-cli": "workspace:*",
    "@coodra/contextos-db": "workspace:*",
    "@coodra/contextos-policy": "workspace:*",
    "@coodra/contextos-shared": "workspace:*",
    "@hono/node-server": "2.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.15",
    "picomatch": "4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/picomatch": "4.0.2",
    "tsx": "^4.21.0"
  }
}
